{
  "name": "vigorcheck",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "devclient:install": "node scripts/dev-client/install-dev-client.js",
    "start:dev": "npm run devclient:install && expo start --dev-client",
    "postinstall": "node scripts/dev-client/eas-install-dev-client.js",
    "eas-build-post-install": "node scripts/dev-client/eas-install-dev-client.js",
    "release:android-native-audit": "node scripts/release/assert-production-android-native.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "branding:generate-icons": "tsx scripts/branding/generate-app-icon-assets.ts",
    "usda:seed": "npx convex run usda:seedStarterCatalog"
  },
  "dependencies": {
    "@better-auth/expo": "^1.5.6",
    "@convex-dev/better-auth": "^0.11.4",
    "@convex-dev/migrations": "^0.3.3",
    "@expo/vector-icons": "^15.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@shopify/react-native-skia": "2.4.18",
    "babel-preset-expo": "~55.0.8",
    "better-auth": "^1.5.6",
    "convex": "^1.34.1",
    "expo": "~55.0.16",
    "expo-auth-session": "~55.0.15",
    "expo-camera": "~55.0.16",
    "expo-constants": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image-manipulator": "~55.0.15",
    "expo-image-picker": "~55.0.19",
    "expo-linking": "~55.0.14",
    "expo-network": "~55.0.13",
    "expo-notifications": "~55.0.20",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "openai": "^6.33.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-purchases": "^9.15.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4",
    "victory-native": "^41.20.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.16",
    "react-test-renderer": "19.2.0",
    "sharp": "^0.34.2",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.ts"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|react-native|react-native-safe-area-context|react-native-gesture-handler)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|expo-router|native-base|react-native-svg)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ]
  },
  "private": true
}
